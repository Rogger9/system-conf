{
  "editor.fontFamily": "Cascadia Code",
  "workbench.colorTheme": "One Dark Pro Flat",
  "editor.fontWeight": "normal",
  "editor.fontLigatures": false,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "none",
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 3,
  "editor.cursorSmoothCaretAnimation": true,
  "files.autoSave": "onFocusChange",
  "editor.fontSize": 14,
  "workbench.iconTheme": "vscode-icons-mac",
  "editor.tabSize": 2,
  "window.zoomLevel": 1, //-.05
  "update.mode": "manual",
  "workbench.colorCustomizations": {
    "editorCursor.foreground": "#F0F0F0"
  },
  "workbench.activityBar.visible": false, // removes the activity bar (the 4 icons at the left of the screen)
  "window.menuBarVisibility": "toggle",
  "breadcrumbs.enabled": false,
  "editor.matchBrackets": "near",
  "editor.occurrencesHighlight": false, //elimina que le resalte la palabra al hacer 1 click
  "editor.multiCursorModifier": "ctrlCmd", // multi cursor
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.cursorWidth": 8,
  "terminal.integrated.fontFamily": "Cascadia Code",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.letterSpacing": 1,
  "editor.inlineSuggest.enabled": true,
  // "editor.tabCompletion": "on",
  // "editor.acceptSuggestionOnEnter": "off",
  // "security.workspace.trust.untrustedFiles": "open",
  "telemetry.telemetryLevel": "off",
  "workbench.editor.showIcons": false, // removes icon from opened files in tabs
  "editor.folding": true, // removes the folding feature (show/hiddle block code)
  "editor.trimAutoWhitespace": true,
  "workbench.editor.tabSizing": "fit",
  "vsicons.presets.hideExplorerArrows": false, // hidden arrows left folders
  // "editor.colorDecorators": false, // Elimina los recuadros de color
  "files.trimTrailingWhitespace": true, // Remueve los espacios extras al final de una línea
  // "explorer.autoReveal": false, // Evita que se desplieguen los archivos al seleccionarlos
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  // "prettier.requireConfig": true,
  "minify.html": {
    "removeComments": true
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  // Prettier
  "prettier.printWidth": 100,
  "prettier.semi": false,
  "prettier.singleQuote": true,
  "prettier.jsxSingleQuote": true,
  "prettier.arrowParens": "avoid",
  "prettier.trailingComma": "none"
}
